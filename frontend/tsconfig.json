{
  "compilerOptions": {
    "target":                          "ES2022",
    "lib":                             ["ES2022", "DOM", "DOM.Iterable"],
    "module":                          "ESNext",
    "moduleResolution":                "bundler",
    "jsx":                             "react-jsx",
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames":true,
    "isolatedModules":                 true,
    "resolveJsonModule":               true,
    "allowImportingTsExtensions":      false,
    "noEmit":                          true,
    "baseUrl":                         ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"]
}
